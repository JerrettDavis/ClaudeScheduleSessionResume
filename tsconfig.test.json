{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "bin-test",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "bin", "bin-test"]
}
